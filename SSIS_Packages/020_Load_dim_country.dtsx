  <DTS:Executables>
      <DTS:Executable DTS:refId="Package\Create_Staging"
        DTS:CreationName="Microsoft.ExecuteSQLTask"
        DTS:DTSID="{2E50A5B2-2639-408B-80E8-78D7A897B151}"
