            xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
        </DTS:ObjectData>
      </DTS:Executable>
      <DTS:Executable DTS:refId="Package\Load_Countries_Comtrade"
        DTS:CreationName="Microsoft.ExecuteSQLTask"
        DTS:DTSID="{A3F19CFC-36B4-406D-A76C-D097540AEE3A}"
        DTS:ExecutableType="Microsoft.ExecuteSQLTask"
        DTS:ObjectName="Load_Countries_Comtrade">
        <DTS:ObjectData>
          <SQLTask:SqlTaskData SQLTask:Connection="{C885D996-D672-43B7-8105-4D5A3D7285B0}"
            SQLTask:SqlStatementSource="IF OBJECT_ID(&apos;stg_comtrade_raw&apos;, &apos;U&apos;) IS NOT NULL
BEGIN
    INSERT INTO dim_country (country_name, is_egypt)
    SELECT DISTINCT LTRIM(RTRIM(CAST(partnerDesc AS NVARCHAR(100)))),
        CASE WHEN partnerDesc LIKE &apos;%Egypt%&apos; THEN 1 ELSE 0 END
    FROM stg_comtrade_raw
    WHERE partnerDesc IS NOT NULL AND LTRIM(RTRIM(CAST(partnerDesc AS NVARCHAR(100)))) != &apos;&apos;
      AND TRY_CAST(partnerCode AS INT) != 0
      AND NOT EXISTS (SELECT 1 FROM dim_country dc WHERE dc.country_name = LTRIM(RTRIM(CAST(stg_comtrade_raw.partnerDesc AS NVARCHAR(100)))));
END"
            SQLTask:ResultType="0"
            SQLTask:BypassPrepare="True"
            xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
        </DTS:ObjectData>
      </DTS:Executable>
  </DTS:Executables>
