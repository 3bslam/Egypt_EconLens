        <DTS:ObjectData>
          <SQLTask:SqlTaskData SQLTask:Connection="{C885D996-D672-43B7-8105-4D5A3D7285B0}"
            SQLTask:SqlStatementSource="IF OBJECT_ID(&apos;stg_comtrade_raw&apos;, &apos;U&apos;) IS NULL BEGIN PRINT &apos;stg_comtrade_raw not found - import via Import Wizard first&apos; END"
            SQLTask:ResultType="0"
