  <DTS:Executables>
      <DTS:Executable DTS:refId="Package\Run_DQ_Checks"
        DTS:CreationName="Microsoft.ExecuteSQLTask"
        DTS:DTSID="{F07DE55D-0404-4A3B-A2D0-9EEBBCADDA83}"
        DTS:ExecutableType="Microsoft.ExecuteSQLTask"
        DTS:ObjectName="Run_DQ_Checks">
        <DTS:ObjectData>
          <SQLTask:SqlTaskData SQLTask:Connection="{C885D996-D672-43B7-8105-4D5A3D7285B0}"
            SQLTask:SqlStatementSource="INSERT INTO dq_validation_log ([year], flow_type, actual_value, [status])
SELECT d.[year], f.flow_type, SUM(f.trade_value_usd),
    CASE WHEN SUM(f.trade_value_usd) &gt; 0 THEN &apos;PASS&apos; ELSE &apos;FAIL&apos; END
FROM fact_trade_flows f
JOIN dim_date d ON f.date_key = d.date_key
GROUP BY d.[year], f.flow_type;"
            SQLTask:ResultType="0"
            SQLTask:BypassPrepare="True"
            xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
        </DTS:ObjectData>
      </DTS:Executable>
      <DTS:Executable DTS:refId="Package\Cleanup_Staging"
        DTS:CreationName="Microsoft.ExecuteSQLTask"
        DTS:DTSID="{5DB5C0E8-354C-448C-8396-B4B5E4EC282F}"
        DTS:ExecutableType="Microsoft.ExecuteSQLTask"
        DTS:ObjectName="Cleanup_Staging">
        <DTS:ObjectData>
          <SQLTask:SqlTaskData SQLTask:Connection="{C885D996-D672-43B7-8105-4D5A3D7285B0}"
            SQLTask:SqlStatementSource="DROP TABLE IF EXISTS stg_comtrade_raw;
DROP TABLE IF EXISTS stg_supply_chain;
DROP TABLE IF EXISTS stg_exchange_rate;
DROP TABLE IF EXISTS stg_world_bank;"
            SQLTask:ResultType="0"
            SQLTask:BypassPrepare="True"
            xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
        </DTS:ObjectData>
      </DTS:Executable>
  </DTS:Executables>
